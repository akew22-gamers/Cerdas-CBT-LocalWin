# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL="your-supabase-url"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-publishable-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# App Configuration
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Setup Wizard Security Token
SETUP_TOKEN="your-secure-random-token"

# Session Configuration
SESSION_EXPIRY_SECONDS=604800
TOKEN_REFRESH_THRESHOLD=3600

# Server-Side Session Inactivity Timeout (seconds)
# Force logout if NO REQUEST received for this duration
# Works even when browser tab is in background (mobile)
SESSION_MAX_INACTIVITY_SECONDS=1800  # 30 minutes

# Client-Side Idle Timeout Configuration (milliseconds)
# Used for active session monitoring with warning dialog
# Student sessions timeout after 10 minutes of inactivity
IDLE_TIMEOUT_SISWA=600000
# Teacher sessions timeout after 30 minutes of inactivity
IDLE_TIMEOUT_GURU=1800000
# Admin sessions timeout after 20 minutes of inactivity
IDLE_TIMEOUT_ADMIN=1200000

# Client-Side Idle warning time before timeout (milliseconds)
# Warning starts 2 minutes before timeout
IDLE_WARNING_TIME=120000

# Mobile idle timeout multiplier
# Mobile devices get 2x longer timeout (accounts for background tabs)
MOBILE_IDLE_TIMEOUT_MULTIPLIER=2.0
