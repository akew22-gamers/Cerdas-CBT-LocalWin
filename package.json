{
  "name": "cerdas-cbt-local",
  "version": "1.0.0",
  "description": "CBT Offline Local Server for Windows",
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "electron:dev": "concurrently \"cross-env BROWSER=none next dev\" \"wait-on http://localhost:3000 && cross-env NODE_ENV=development electron .\"",
    "electron:rebuild": "electron-rebuild -f -w better-sqlite3",
    "electron:build": "npm run build && npm run electron:rebuild && electron-builder",
    "electron:build:win": "npm run build && npm run electron:rebuild && electron-builder --win --x64",
    "electron:build:linux": "npm run build && npm run electron:rebuild && electron-builder --linux --x64",
    "electron:preview": "cross-env NODE_ENV=production electron .",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/akew22-gamers/Cerdas-CBT-LocalWin.git"
  },
  "keywords": [
    "cbt",
    "exam",
    "offline",
    "electron",
    "windows"
  ],
  "author": "EAS Creative Studio",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/akew22-gamers/Cerdas-CBT-LocalWin/issues"
  },
  "homepage": "https://github.com/akew22-gamers/Cerdas-CBT-LocalWin#readme",
  "build": {
    "appId": "com.cerdas.cbt-local",
    "productName": "CBT Server Local",
    "copyright": "Copyright © 2024 EAS Creative Studio",
    "files": [
      ".next/standalone/**/*",
      ".next/static/**/*",
      "node_modules/**/*",
      "electron/**/*",
      "public/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release",
      "buildResources": "electron/resources"
    },
    "extraResources": [
      {
        "from": "data",
        "to": "data",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/resources/icon.ico",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "electron/resources/icon.ico",
      "uninstallerIcon": "electron/resources/icon.ico",
      "installerHeaderIcon": "electron/resources/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CBT Server Local",
      "license": "LICENSE",
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/resources/icons",
      "category": "Education",
      "maintainer": "eas.creative.studio@gmail.com",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "deb": {
      "packageCategory": "education",
      "priority": "optional"
    },
    "extraMetadata": {
      "main": "electron/main.js"
    }
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@radix-ui/react-switch": "^1.2.6",
    "@react-pdf/renderer": "^4.3.3",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "browser-image-compression": "^2.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "file-saver": "^2.0.5",
    "html5-qrcode": "^2.3.8",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.1",
    "katex": "^0.16.44",
    "lucide-react": "^1.7.0",
    "next": "^16.2.1",
    "next-themes": "^0.4.6",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-katex": "^3.1.0",
    "shadcn": "^4.1.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^13.0.0",
    "wait-on": "^9.0.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@playwright/test": "^1.58.2",
    "@swc/jest": "^0.2.39",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.11",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^25.5.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.27",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
